{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://fidelity-checker-api.fly.dev/api/$1" },
    { "source": "/feedback", "destination": "/index.html" },
    { "source": "/history", "destination": "/index.html" },
    { "source": "/report", "destination": "/index.html" }
  ]
}

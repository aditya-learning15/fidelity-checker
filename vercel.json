{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "regions": ["sin"],
  "functions": {
    "api/**": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://fidelity-checker-api.fly.dev/api/$1"
    },
    {
      "source": "/(?!api)",
      "destination": "/index.html"
    }
  ]
}

{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "https://fidelity-checker-api.fly.dev/api/$1" },
    { "src": "/feedback$", "dest": "/index.html" },
    { "src": "/history$", "dest": "/index.html" },
    { "src": "/report$", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
